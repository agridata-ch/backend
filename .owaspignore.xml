    <!--
        opentelemetry-semconv (transitive)
        No fix released yet; expected with the next Quarkus release.

        opentelemetry-semconv is a pure constants/attribute-name library without runtime
        logic. Additionally, the project does not declare quarkus-opentelemetry, so no
        OTel exporter or instrumentation pipeline is active.
    -->
    <suppress until="2026-07-31Z">
        <!-- started: 2026-05-04 | affected: NO (constants-only lib, OTel not enabled) -->
        <cve>CVE-2026-39883</cve>
    </suppress>
    <suppress until="2026-07-31Z">
        <!-- started: 2026-05-04 | affected: NO (constants-only lib, OTel not enabled) -->
        <cve>CVE-2026-29181</cve>
    </suppress>

    <!--
        Netty HTTP/3 QPACK (memory exhaustion via crafted requests)
        Fixed in netty 4.2.13; Quarkus has not bumped yet.

        HTTP/3 is not enabled (quarkus.http.http3.* unset, no QUIC listener configured).
        The vulnerable QPACK decoder is never instantiated.
    -->
    <suppress until="2026-07-31Z">
        <!-- started: 2026-06-15 | affected: NO (HTTP/3 not enabled) -->
        <cve>CVE-2026-42582</cve>
    </suppress>
