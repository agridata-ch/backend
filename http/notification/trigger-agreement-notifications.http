### Locally load admin into user cache (if not already loaded)
GET {{baseUrl}}/user/v1/user-info
Authorization: Bearer {{$auth.token("admin")}}
Content-Type: application/json

> {%
  client.test("Load admin user", function () {
    client.assert(response.status === 200, "Expected Response status is 200, got: " + response.status)
    client.assert(response.body !== null, "Expected Response results to contain products")
  })
%}

### Locally load consumer 1 into user cache (if not already loaded)
GET {{baseUrl}}/user/v1/user-info
Authorization: Bearer {{$auth.token("consumer-blv-1")}}
Content-Type: application/json

> {%
  client.test("Load consumer 1 user", function () {
    client.assert(response.status === 200, "Expected Response status is 200, got: " + response.status)
    client.assert(response.body !== null, "Expected Response results to contain products")
    client.global.set("consumerUid", response.body.uid)
  })
%}

