### Initiate seal of the final contract revision (admin)
POST {{baseUrl}}/agreement/v1/contract-revisions/{{contractRevisionId}}/seals?adminGlobalId=test-admin-global-id
Authorization: Bearer {{$auth.token("admin")}}

> {%
  client.test("Initiate seal", function () {
    client.assert(response.status === 202, "Expected 202, got: " + response.status)
  })
%}

### Poll seal status (long polling — waits until seal completes)
GET {{baseUrl}}/agreement/v1/contract-revisions/{{contractRevisionId}}/seals/status?longPolling=true
Authorization: Bearer {{$auth.token("admin")}}

> {%
  client.test("Seal completed", function () {
    client.assert(response.status === 200, "Expected 200, got: " + response.status)
    client.assert(response.body === "COMPLETED", "Expected seal status COMPLETED, got: " + response.body)
  })
%}

