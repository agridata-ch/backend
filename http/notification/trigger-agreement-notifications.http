    client.assert(response.status === 200, "Expected 200, got: " + response.status)
    client.global.set("contractRevisionId", response.body.currentContractRevisionId)
  })
%}

### Initiate OTP challenge for consumer 1 signature (DATA_CONSUMER_01)
POST {{baseUrl}}/agreement/v1/contract-revisions/{{contractRevisionId}}/signatures/DATA_CONSUMER_01/otp-challenges
Authorization: Bearer {{$auth.token("consumer-blv-1")}}

> {%
  client.test("Initiate OTP challenge for consumer 1", function () {
    client.assert(response.status === 200, "Expected 200, got: " + response.status)
    client.global.set("challengeId", response.body.challengeId)
  })
%}

### Verify OTP and sign as consumer 1 (DATA_CONSUMER_01)
POST {{baseUrl}}/agreement/v1/contract-revisions/{{contractRevisionId}}/signatures/DATA_CONSUMER_01/otp-challenges/{{challengeId}}/verification
Authorization: Bearer {{$auth.token("consumer-blv-1")}}
Content-Type: application/json

{
  "otpCode": "123456"
}

> {%
  client.test("Sign as consumer 1", function () {
    client.assert(response.status === 200, "Expected 200, got: " + response.status)
    client.global.set("contractRevisionId", response.body.id)
  })
%}

